{
    "name": "PHP Development",
    "image": "mcr.microsoft.com/devcontainers/php:8.2",
    "features": {
        "ghcr.io/devcontainers/features/php:1": {
            "version": "8.2"
        }
    },
    "forwardPorts": [8000],
    "postCreateCommand": "php -S 0.0.0.0:8000 -t .",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug"
            ]
        }
    }
}
